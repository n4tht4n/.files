# Include any "local" config...
Include config_local

Host *
  # Make sure to use a "compatible" TERM when connecting to any host ;)
  SetEnv TERM=xterm-256color
  GSSAPIAuthentication no
  IPQoS lowdelay throughput

{{- if (and (ne .env "server") (ne .env "work")) }}
# Sample for host specific SSH keys (only available on non-server environments)
Host github.com
  AddKeysToAgent yes
  UseKeychain yes
  IdentityFile ~/.ssh/id_ed25519
{{- end }}
